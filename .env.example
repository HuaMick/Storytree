# Copy to .env and fill in. .env is gitignored.

# --- Model providers (pi routes to whichever you configure) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# ...add others as needed; pi supports 15+ providers.

# --- Durable execution (DBOS) ---
# Local Postgres via Docker:
#   docker run -d --name storytree-pg -e POSTGRES_PASSWORD=storytree -p 5432:5432 postgres:16
DATABASE_URL=postgres://postgres:storytree@localhost:5432/storytree
